# GygesLink — règles iptables bypass (mode pause)
# Le trafic du PC passe directement par wlan0 sans passer par Tor.
# Tor continue de tourner pour une reprise quasi instantanée.
#
# NOTE : la règle DNAT pour le DNS est injectée dynamiquement par
# gygeslink-iptables.sh (gateway détectée via `ip route show default`).
# Ce fichier est un template — il ne contient PAS la ligne DNAT.

# ─────────────────────────────────────────────────────────────────────
# TABLE NAT — aucun redirect vers Tor, masquerade sortant
# ─────────────────────────────────────────────────────────────────────
*nat
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]

# Masquerade le trafic du PC qui sort par wlan0
# (le routeur FAI voit l'IP wlan0 du Pi, pas 192.168.100.x)
-A POSTROUTING -o wlan0 -j MASQUERADE

COMMIT

# ─────────────────────────────────────────────────────────────────────
# TABLE MANGLE
# ─────────────────────────────────────────────────────────────────────
*mangle
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:FORWARD ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]

-A FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu

COMMIT

# ─────────────────────────────────────────────────────────────────────
# TABLE FILTER — forwarding autorisé usb0→wlan0
# ─────────────────────────────────────────────────────────────────────
*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT DROP [0:0]

# Noise daemon bloqué (Tor bypassé, pas de leurre utile)
-A OUTPUT -m owner --uid-owner gygeslink-noise -j DROP

# Loopback
-A INPUT -i lo -j ACCEPT
-A OUTPUT -o lo -j ACCEPT

# Connexions établies
-A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
-A OUTPUT -m state --state ESTABLISHED,RELATED -j ACCEPT

# DHCP serveur sur usb0
-A INPUT -i usb0 -p udp --dport 67 -j ACCEPT
-A OUTPUT -o usb0 -p udp --sport 67 -j ACCEPT

# DHCP client wlan0
-A INPUT -i wlan0 -p udp --sport 67 --dport 68 -j ACCEPT
-A OUTPUT -o wlan0 -p udp --sport 68 --dport 67 -j ACCEPT

# DNS entrant sur usb0 (le Pi forward les requêtes DNS du PC vers le routeur)
-A INPUT -i usb0 -p udp --dport 53 -j ACCEPT
-A OUTPUT -o wlan0 -p udp --dport 53 -j ACCEPT
-A INPUT -i wlan0 -p udp --sport 53 -j ACCEPT

# FORWARD usb0→wlan0 : le trafic du PC traverse le Pi en direct
-A FORWARD -i usb0 -o wlan0 -j ACCEPT
-A FORWARD -i wlan0 -o usb0 -m state --state ESTABLISHED,RELATED -j ACCEPT

# SSH sur usb0
-A INPUT -i usb0 -p tcp --dport 22 -j ACCEPT
-A OUTPUT -o usb0 -p tcp --sport 22 -j ACCEPT

# API REST pour l'app desktop (port 4430, usb0 uniquement)
-A INPUT -i usb0 -p tcp --dport 4430 -j ACCEPT
-A OUTPUT -o usb0 -p tcp --sport 4430 -j ACCEPT

# Setup portal HTTPS (port 443, usb0 uniquement)
-A INPUT -i usb0 -p tcp --dport 443 -j ACCEPT
-A OUTPUT -o usb0 -p tcp --sport 443 -j ACCEPT

# NTP sortant
-A OUTPUT -o wlan0 -p udp --dport 123 -j ACCEPT

# Tor daemon (continue de tourner pour reprise rapide)
-A OUTPUT -m owner --uid-owner debian-tor -j ACCEPT

COMMIT